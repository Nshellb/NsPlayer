<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:orientation="vertical">

    <include
        android:id="@+id/advancedTopBarInclude"
        layout="@layout/include_top_bar" />

    <LinearLayout
        android:id="@+id/advancedSettingsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/advancedLanguageRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/advancedLanguageTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/advanced_settings_language"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Body1" />

            <Spinner
                android:id="@+id/advancedLanguageSpinner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:entries="@array/advanced_language_entries"
                android:spinnerMode="dropdown" />
        </LinearLayout>

        <View
            android:id="@+id/advancedDividerLanguage"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="?android:attr/textColorSecondary"
            android:alpha="0.12" />

        <LinearLayout
            android:id="@+id/advancedThemeRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/advancedThemeTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/advanced_settings_theme"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Body1" />

            <Spinner
                android:id="@+id/advancedThemeSpinner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:entries="@array/advanced_theme_entries"
                android:spinnerMode="dropdown" />
        </LinearLayout>

        <View
            android:id="@+id/advancedDividerTheme"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="?android:attr/textColorSecondary"
            android:alpha="0.12" />

        <include
            android:id="@+id/advancedSearchFoldersRow"
            layout="@layout/include_settings_row_chevron" />

        <View
            android:id="@+id/advancedDividerSearchFolders"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="?android:attr/textColorSecondary"
            android:alpha="0.12" />

        <TextView
            android:id="@+id/advancedVisibleItemsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/advanced_settings_visible_items"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body1" />

        <include
            layout="@layout/include_visible_items_grid" />

        <View
            android:id="@+id/advancedDividerVisibleItems"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="?android:attr/textColorSecondary"
            android:alpha="0.12" />

        <include
            android:id="@+id/advancedNoMediaRow"
            layout="@layout/include_settings_row_checkbox" />

        <View
            android:id="@+id/advancedDividerNoMedia"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="?android:attr/textColorSecondary"
            android:alpha="0.12" />

        <include
            android:id="@+id/advancedAutoPipRow"
            layout="@layout/include_settings_row_checkbox" />

        <View
            android:id="@+id/advancedDividerAutoPip"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="?android:attr/textColorSecondary"
            android:alpha="0.12" />

        <LinearLayout
            android:id="@+id/advancedTranslationEngineContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/advancedTranslationEngineRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/advancedTranslationEngineTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/advanced_settings_translation_engine"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Body1" />

                <Spinner
                    android:id="@+id/advancedTranslationEngineSpinner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:spinnerMode="dropdown" />
            </LinearLayout>

            <TextView
                android:id="@+id/advancedTranslationEngineHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                android:textColor="?android:attr/textColorSecondary"
                android:visibility="gone" />
        </LinearLayout>

        <View
            android:id="@+id/advancedDividerTranslationEngine"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="?android:attr/textColorSecondary"
            android:alpha="0.12" />

        <include
            android:id="@+id/advancedInquiryRow"
            layout="@layout/include_settings_row_chevron" />
    </LinearLayout>
</LinearLayout>
